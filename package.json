{
  "name": "squish-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "squish": "./bin/squish.ts"
  },
  "scripts": {
    "dev": "bun run --watch ./bin/squish.ts",
    "build": "bun build ./bin/squish.ts --outdir dist --target bun",
    "bundle": "bun build ./bin/squish.ts --compile --outfile dist/squish",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.7.3",
    "bun-types": "^1.2.4"
  }
}
